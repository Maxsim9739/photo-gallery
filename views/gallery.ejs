<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Фотогалерея</title>
    <style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: linear-gradient(135deg, #1a0a0a 0%, #2d1b1b 30%, #1a1a2e 70%, #0a0a1a 100%);
    min-height: 100vh;
    color: #e0d5d5;
}

.container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 20px;
}

.header {
    background: linear-gradient(135deg, rgba(139, 90, 43, 0.3), rgba(183, 130, 100, 0.2));
    padding: 25px 30px;
    border-radius: 15px;
    margin-bottom: 30px;
    border: 1px solid rgba(183, 130, 100, 0.3);
    display: flex;
    justify-content: space-between;
    align-items: center;
    backdrop-filter: blur(10px);
}

.header h1 {
    font-size: 2.2em;
    background: linear-gradient(135deg, #c9a96e, #e8c4a2, #d4a574);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.role-badge {
    padding: 8px 18px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: bold;
}

.role-editor {
    background: linear-gradient(135deg, #c9a96e, #b8860b);
    color: #1a0a0a;
    box-shadow: 0 0 15px rgba(201, 169, 110, 0.3);
}

.role-guest {
    background: linear-gradient(135deg, #e8c4a2, #d4a574);
    color: #1a0a0a;
    box-shadow: 0 0 15px rgba(232, 196, 162, 0.3);
}

.gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 25px;
}

.photo-card {
    background: linear-gradient(145deg, rgba(45, 27, 27, 0.8), rgba(26, 26, 46, 0.8));
    border-radius: 15px;
    overflow: hidden;
    border: 1px solid rgba(183, 130, 100, 0.2);
    transition: all 0.4s ease;
}

.photo-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 35px rgba(201, 169, 110, 0.2), 0 0 20px rgba(232, 196, 162, 0.1);
    border-color: rgba(201, 169, 110, 0.5);
}

.photo-image {
    width: 100%;
    height: 260px;
    object-fit: cover;
    cursor: pointer;
    transition: all 0.5s;
}

.photo-card:hover .photo-image {
    transform: scale(1.05);
    filter: brightness(1.1);
}

.photo-info {
    padding: 20px;
}

.photo-title {
    font-size: 1.2em;
    color: #e8c4a2;
    margin-bottom: 8px;
    font-weight: 500;
}

.photo-description {
    color: #b8a9a9;
    font-size: 0.9em;
    line-height: 1.5;
    margin-bottom: 15px;
}

.photo-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 15px;
    padding-top: 15px;
    border-top: 1px solid rgba(183, 130, 100, 0.2);
}

.photo-date {
    color: #8a7a7a;
    font-size: 0.85em;
}

.like-section {
    display: flex;
    align-items: center;
    gap: 10px;
}

.btn {
    padding: 10px 22px;
    border: none;
    border-radius: 25px;
    font-size: 15px;
    cursor: pointer;
    transition: all 0.3s;
    text-decoration: none;
    font-weight: 500;
}

.btn-primary {
    background: linear-gradient(135deg, #c9a96e, #b8860b);
    color: #1a0a0a;
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(201, 169, 110, 0.4);
}

.btn-outline {
    background: transparent;
    border: 2px solid #c9a96e;
    color: #c9a96e;
}

.btn-outline:hover {
    background: #c9a96e;
    color: #1a0a0a;
}

.btn-danger {
    background: linear-gradient(135deg, #8b0000, #4a0000);
    color: #e0d5d5;
}

.btn-danger:hover {
    background: #a00000;
    box-shadow: 0 0 15px rgba(139, 0, 0, 0.4);
}

.btn-like {
    background: none;
    border: 2px solid rgba(183, 130, 100, 0.3);
    border-radius: 50%;
    width: 42px;
    height: 42px;
    font-size: 1.2em;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
}

.btn-like:hover {
    border-color: #e8c4a2;
    transform: scale(1.1);
    box-shadow: 0 0 15px rgba(232, 196, 162, 0.3);
}

.btn-like.liked {
    background: linear-gradient(135deg, #e8a0a0, #d47070);
    border-color: #e8a0a0;
    animation: heartbeat 0.6s ease;
}

@keyframes heartbeat {
    0%, 100% { transform: scale(1); }
    25% { transform: scale(1.2); }
    50% { transform: scale(1); }
    75% { transform: scale(1.15); }
}

.like-count {
    color: #e8c4a2;
    font-weight: bold;
}

.editor-controls {
    display: flex;
    gap: 10px;
    margin-top: 15px;
}

.upload-form {
    background: linear-gradient(145deg, rgba(45, 27, 27, 0.9), rgba(26, 26, 46, 0.9));
    padding: 30px;
    border-radius: 15px;
    margin-bottom: 30px;
    border: 1px solid rgba(183, 130, 100, 0.3);
}

.upload-form h2 {
    color: #e8c4a2;
    margin-bottom: 20px;
}

.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    margin-bottom: 8px;
    color: #c9a96e;
    font-weight: bold;
}

.form-group input,
.form-group textarea {
    width: 100%;
    padding: 12px;
    background: rgba(26, 26, 46, 0.6);
    border: 1px solid rgba(183, 130, 100, 0.3);
    border-radius: 8px;
    color: #e0d5d5;
    font-size: 16px;
}

.form-group input:focus,
.form-group textarea:focus {
    outline: none;
    border-color: #c9a96e;
}

.file-upload-label {
    padding: 12px 24px;
    background: rgba(201, 169, 110, 0.1);
    border: 2px dashed rgba(201, 169, 110, 0.4);
    border-radius: 8px;
    cursor: pointer;
    color: #c9a96e;
}

.file-upload-label:hover {
    border-color: #c9a96e;
    background: rgba(201, 169, 110, 0.2);
}

.modal {
    display: none;
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background: rgba(10, 5, 5, 0.95);
    backdrop-filter: blur(15px);
    animation: fadeIn 0.3s;
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

.modal-close {
    position: absolute;
    right: 30px;
    top: 20px;
    color: #c9a96e;
    font-size: 45px;
    cursor: pointer;
}

.modal-close:hover {
    color: #e8c4a2;
    transform: rotate(90deg);
}

.modal-content {
    margin: auto;
    padding: 20px;
    width: 90%;
    max-width: 1100px;
    position: relative;
    top: 50%;
    transform: translateY(-50%);
}

.modal-image {
    width: 100%;
    max-height: 75vh;
    object-fit: contain;
    border-radius: 10px;
    border: 1px solid rgba(201, 169, 110, 0.3);
    box-shadow: 0 0 40px rgba(201, 169, 110, 0.2);
}

#modalTitle {
    color: #e8c4a2;
    margin-top: 20px;
}

#modalDescription {
    color: #b8a9a9;
    margin-top: 10px;
}

.upload-section {
    display: none;
}

.upload-section.active {
    display: block;
}

@media (max-width: 768px) {
    .header {
        flex-direction: column;
        gap: 15px;
    }
    .gallery {
        grid-template-columns: 1fr;
    }
}
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🖼️ Фотогалерея</h1>
            <div class="user-controls">
                <% if (userRole === 'editor') { %>
                    <span class="role-badge role-editor">👑 Редактор</span>
                    <button class="btn btn-primary" onclick="toggleUploadForm()">
                        📤 Загрузить фото
                    </button>
                    <a href="/logout" class="btn btn-outline">Выйти</a>
                <% } else { %>
                    <span class="role-badge role-guest">👤 Гость</span>
                    <a href="/login" class="btn btn-primary">Войти как редактор</a>
                <% } %>
            </div>
        </div>

        <!-- Форма загрузки (только для редактора) -->
        <% if (userRole === 'editor') { %>
        <div id="uploadSection" class="upload-section">
            <div class="upload-form">
                <h2>Загрузить новое фото</h2>
                <form id="uploadForm" enctype="multipart/form-data">
                    <div class="form-group">
                        <label>Выберите фото:</label>
                        <div class="file-upload">
                            <label for="photoInput" class="file-upload-label">
                                📁 Выбрать файл
                            </label>
                            <input type="file" id="photoInput" name="photo" accept="image/*" required>
                        </div>
                        <span id="fileName" style="margin-left: 10px; color: #666;"></span>
                    </div>
                    <div class="form-group">
                        <label for="photoTitle">Название:</label>
                        <input type="text" id="photoTitle" name="title" placeholder="Введите название фото">
                    </div>
                    <div class="form-group">
                        <label for="photoDescription">Описание:</label>
                        <textarea id="photoDescription" name="description" placeholder="Добавьте описание..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Загрузить</button>
                    <button type="button" class="btn btn-outline" onclick="toggleUploadForm()">Отмена</button>
                </form>
            </div>
        </div>
        <% } %>

        <!-- Галерея -->
        <div class="gallery" id="gallery">
            <% photos.forEach(photo => { %>
            <div class="photo-card" data-id="<%= photo.id %>">
                <img src="/uploads/<%= photo.filename %>" 
                     alt="<%= photo.title %>" 
                     class="photo-image"
                     onclick="openModal('/uploads/<%= photo.filename %>', '<%= photo.title %>', '<%= photo.description %>')">
                <div class="photo-info">
                    <h3 class="photo-title"><%= photo.title %></h3>
                    <p class="photo-description"><%= photo.description %></p>
                    <div class="photo-meta">
                        <span class="photo-date">
                            📅 <%= new Date(photo.uploadDate).toLocaleDateString('ru-RU') %>
                        </span>
                        <div class="like-section">
                            <button class="btn-like <%= photo.isLiked ? 'liked' : '' %>" 
                                    onclick="toggleLike(<%= photo.id %>, this)">
                                <%= photo.isLiked ? '❤️' : '🤍' %>
                            </button>
                            <span class="like-count"><%= photo.likes %></span>
                        </div>
                    </div>
                    <% if (userRole === 'editor') { %>
                    <div class="editor-controls">
                        <button class="btn btn-outline btn-sm" onclick="editPhoto(<%= photo.id %>)">
                            ✏️ Редактировать
                        </button>
                        <button class="btn btn-danger btn-sm" onclick="deletePhoto(<%= photo.id %>)">
                            🗑️ Удалить
                        </button>
                    </div>
                    <% } %>
                </div>
            </div>
            <% }); %>
        </div>
    </div>

    <!-- Модальное окно для просмотра фото -->
    <div id="imageModal" class="modal">
        <span class="modal-close" onclick="closeModal()">&times;</span>
        <div class="modal-content">
            <img id="modalImage" class="modal-image">
            <h2 id="modalTitle" style="color: white; margin-top: 20px;"></h2>
            <p id="modalDescription" style="color: #ccc;"></p>
        </div>
    </div>

    <script>
        // Функции для модального окна
        function openModal(imageSrc, title, description) {
            document.getElementById('imageModal').style.display = 'block';
            document.getElementById('modalImage').src = imageSrc;
            document.getElementById('modalTitle').textContent = title;
            document.getElementById('modalDescription').textContent = description;
        }

        function closeModal() {
            document.getElementById('imageModal').style.display = 'none';
        }

        // Закрытие модального окна по клику вне изображения
        window.onclick = function(event) {
            const modal = document.getElementById('imageModal');
            if (event.target == modal) {
                closeModal();
            }
        }

        // Функции для лайков
        async function toggleLike(photoId, button) {
            try {
                const response = await fetch(`/photo/${photoId}/like`, {
                    method: 'POST'
                });
                const data = await response.json();
                
                if (data.success) {
                    // Обновляем иконку и счетчик
                    button.innerHTML = data.liked ? '❤️' : '🤍';
                    button.className = `btn-like ${data.liked ? 'liked' : ''}`;
                    button.parentElement.querySelector('.like-count').textContent = data.likes;
                }
            } catch (error) {
                console.error('Ошибка при обработке лайка:', error);
            }
        }

        // Функции для редактора
        function toggleUploadForm() {
            const uploadSection = document.getElementById('uploadSection');
            if (uploadSection) {
                uploadSection.classList.toggle('active');
            }
        }

        // Отображение имени выбранного файла
        document.getElementById('photoInput')?.addEventListener('change', function(e) {
            const fileName = e.target.files[0]?.name || '';
            document.getElementById('fileName').textContent = fileName;
        });

        // Загрузка фото
        document.getElementById('uploadForm')?.addEventListener('submit', async function(e) {
            e.preventDefault();
            const formData = new FormData(this);
            
            try {
                const response = await fetch('/upload', {
                    method: 'POST',
                    body: formData
                });
                const data = await response.json();
                
                if (data.success) {
                    location.reload();
                } else {
                    alert('Ошибка загрузки: ' + data.error);
                }
            } catch (error) {
                console.error('Ошибка:', error);
                alert('Ошибка при загрузке фото');
            }
        });

        // Удаление фото
        async function deletePhoto(photoId) {
            if (!confirm('Вы уверены, что хотите удалить это фото?')) {
                return;
            }
            
            try {
                const response = await fetch(`/photo/${photoId}`, {
                    method: 'DELETE'
                });
                const data = await response.json();
                
                if (data.success) {
                    location.reload();
                } else {
                    alert('Ошибка удаления: ' + data.error);
                }
            } catch (error) {
                console.error('Ошибка:', error);
                alert('Ошибка при удалении фото');
            }
        }

        // Редактирование фото
        async function editPhoto(photoId) {
            const newTitle = prompt('Введите новое название:', '');
            if (newTitle === null) return;
            
            const newDescription = prompt('Введите новое описание:', '');
            if (newDescription === null) return;
            
            try {
                const response = await fetch(`/photo/${photoId}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        title: newTitle,
                        description: newDescription
                    })
                });
                const data = await response.json();
                
                if (data.success) {
                    location.reload();
                } else {
                    alert('Ошибка редактирования: ' + data.error);
                }
            } catch (error) {
                console.error('Ошибка:', error);
                alert('Ошибка при редактировании фото');
            }
        }

        // Закрытие модального окна по клавише Escape
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                closeModal();
            }
        });
    </script>
</body>
</html>